{
  "version": "1.0",
  "name": "origination-expire-stale-tasks",
  "description": "Expires stale origination tasks: offers past their deadline and drafts inactive beyond threshold.",
  "timeout": "5m",
  "on_error": {
    "action": "fail"
  },
  "steps": [
    {
      "id": "expire_offers",
      "type": "call",
      "name": "Expire stale loan offers",
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://service-origination.fintech.svc/internal/jobs/expire-offers",
          "method": "POST",
          "headers": {
            "Content-Type": "application/json"
          }
        },
        "output_var": "expire_offers_result"
      },
      "retry": {
        "max_attempts": 3,
        "backoff": "30s"
      }
    },
    {
      "id": "clean_drafts",
      "type": "call",
      "name": "Clean expired draft applications",
      "call": {
        "action": "http.request",
        "input": {
          "url": "http://service-origination.fintech.svc/internal/jobs/clean-drafts",
          "method": "POST",
          "headers": {
            "Content-Type": "application/json"
          }
        },
        "output_var": "clean_drafts_result"
      },
      "retry": {
        "max_attempts": 3,
        "backoff": "30s"
      }
    }
  ]
}
