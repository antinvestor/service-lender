#!/usr/bin/env bash
# Pre-commit hook: format Go code before committing
set -e

# Only run on Go files
GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
if [ -n "$GO_FILES" ]; then
    echo "Running goimports..."
    goimports -w $GO_FILES 2>/dev/null || true
    echo "Running golines..."
    golines -w --max-len=120 $GO_FILES 2>/dev/null || true
    # Re-stage formatted files
    git add $GO_FILES
fi
