{
  "version": "1.0",
  "name": "sacco_loan_origination",
  "description": "Orchestrates loan origination: generate offers, wait for member response, source funding, create loan, and disburse",
  "timeout": "14d",
  "input": {
    "group_id": "string",
    "member_id": "string",
    "loan_window_id": "string"
  },
  "retry_policy": {
    "default": {
      "max_attempts": 3,
      "backoff": "exponential",
      "initial_interval": "5s",
      "max_interval": "60s"
    },
    "disbursement": {
      "max_attempts": 5,
      "backoff": "exponential",
      "initial_interval": "10s",
      "max_interval": "120s"
    }
  },
  "steps": [
    {
      "id": "check_eligibility",
      "type": "call",
      "call": {
        "action": "http.request",
        "input": {
          "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/members/{{ payload.member_id }}/loan-eligibility",
          "method": "GET"
        },
        "output_var": "eligibility",
        "retry": "default"
      }
    },
    {
      "id": "check_eligible",
      "type": "if",
      "if": {
        "expr": "vars.eligibility.body.eligible == false",
        "then": [
          {
            "id": "notify_ineligible",
            "type": "call",
            "call": {
              "action": "notification.send",
              "input": {
                "template": "loan_ineligible",
                "data": {
                  "member_id": "{{ payload.member_id }}",
                  "reason": "{{ vars.eligibility.body.reason }}"
                }
              }
            }
          },
          {
            "id": "end_ineligible",
            "type": "return",
            "return": {
              "status": "ineligible",
              "reason": "{{ vars.eligibility.body.reason }}"
            }
          }
        ]
      }
    },
    {
      "id": "generate_offers",
      "type": "call",
      "call": {
        "action": "http.request",
        "input": {
          "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/members/{{ payload.member_id }}/generate-loan-offers",
          "method": "POST",
          "body": {
            "loan_window_id": "{{ payload.loan_window_id }}"
          }
        },
        "output_var": "offers",
        "retry": "default"
      }
    },
    {
      "id": "notify_offers_available",
      "type": "call",
      "call": {
        "action": "notification.send",
        "input": {
          "template": "loan_offers_available",
          "data": {
            "member_id": "{{ payload.member_id }}",
            "group_id": "{{ payload.group_id }}",
            "offer_count": "{{ vars.offers.body.offer_count }}",
            "max_amount": "{{ vars.offers.body.max_amount }}"
          }
        }
      }
    },
    {
      "id": "wait_for_offer_response",
      "type": "signal_wait",
      "signal_wait": {
        "signal": "loan_offer_response",
        "filter": {
          "member_id": "{{ payload.member_id }}",
          "group_id": "{{ payload.group_id }}"
        },
        "timeout": "48h",
        "output_var": "offer_response"
      }
    },
    {
      "id": "check_offer_accepted",
      "type": "if",
      "if": {
        "expr": "vars.offer_response == null || vars.offer_response.accepted == false",
        "then": [
          {
            "id": "check_timeout_vs_declined",
            "type": "if",
            "if": {
              "expr": "vars.offer_response == null",
              "then": [
                {
                  "id": "notify_offer_expired",
                  "type": "call",
                  "call": {
                    "action": "notification.send",
                    "input": {
                      "template": "loan_offer_expired",
                      "data": {
                        "member_id": "{{ payload.member_id }}",
                        "group_id": "{{ payload.group_id }}"
                      }
                    }
                  }
                }
              ],
              "else": [
                {
                  "id": "notify_offer_declined",
                  "type": "call",
                  "call": {
                    "action": "notification.send",
                    "input": {
                      "template": "loan_offer_declined",
                      "data": {
                        "member_id": "{{ payload.member_id }}",
                        "group_id": "{{ payload.group_id }}"
                      }
                    }
                  }
                }
              ]
            }
          },
          {
            "id": "expire_offers",
            "type": "call",
            "call": {
              "action": "http.request",
              "input": {
                "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/members/{{ payload.member_id }}/expire-loan-offers",
                "method": "POST"
              },
              "retry": "default"
            }
          },
          {
            "id": "end_no_acceptance",
            "type": "return",
            "return": {
              "status": "not_accepted"
            }
          }
        ]
      }
    },
    {
      "id": "send_reminder_delay",
      "description": "Wait 24h before the deadline to send a reminder, only reached if offer was accepted and we continue",
      "type": "noop"
    },
    {
      "id": "source_funding",
      "type": "call",
      "call": {
        "action": "http.request",
        "input": {
          "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/loans/source-funding",
          "method": "POST",
          "body": {
            "member_id": "{{ payload.member_id }}",
            "offer_id": "{{ vars.offer_response.offer_id }}",
            "amount": "{{ vars.offer_response.amount }}"
          }
        },
        "output_var": "funding_result",
        "retry": "default"
      }
    },
    {
      "id": "check_funding_available",
      "type": "if",
      "if": {
        "expr": "vars.funding_result.body.funded == false",
        "then": [
          {
            "id": "notify_funding_unavailable",
            "type": "call",
            "call": {
              "action": "notification.send",
              "input": {
                "template": "loan_funding_unavailable",
                "data": {
                  "member_id": "{{ payload.member_id }}",
                  "group_id": "{{ payload.group_id }}",
                  "shortfall": "{{ vars.funding_result.body.shortfall }}"
                }
              }
            }
          },
          {
            "id": "end_no_funding",
            "type": "return",
            "return": {
              "status": "funding_unavailable",
              "shortfall": "{{ vars.funding_result.body.shortfall }}"
            }
          }
        ]
      }
    },
    {
      "id": "create_loan",
      "type": "call",
      "call": {
        "action": "http.request",
        "input": {
          "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/loans",
          "method": "POST",
          "body": {
            "member_id": "{{ payload.member_id }}",
            "offer_id": "{{ vars.offer_response.offer_id }}",
            "amount": "{{ vars.offer_response.amount }}",
            "funding_source_id": "{{ vars.funding_result.body.funding_source_id }}"
          }
        },
        "output_var": "loan",
        "retry": "default"
      }
    },
    {
      "id": "generate_repayment_schedule",
      "type": "call",
      "call": {
        "action": "http.request",
        "input": {
          "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/loans/{{ vars.loan.body.loan_id }}/generate-schedule",
          "method": "POST"
        },
        "output_var": "schedule",
        "retry": "default"
      }
    },
    {
      "id": "disburse_loan",
      "type": "call",
      "call": {
        "action": "http.request",
        "input": {
          "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/loans/{{ vars.loan.body.loan_id }}/disburse",
          "method": "POST"
        },
        "output_var": "disbursement",
        "retry": "disbursement"
      }
    },
    {
      "id": "notify_disbursement",
      "type": "call",
      "call": {
        "action": "notification.send",
        "input": {
          "template": "loan_disbursed",
          "data": {
            "member_id": "{{ payload.member_id }}",
            "group_id": "{{ payload.group_id }}",
            "loan_id": "{{ vars.loan.body.loan_id }}",
            "amount": "{{ vars.offer_response.amount }}",
            "transaction_ref": "{{ vars.disbursement.body.transaction_ref }}"
          }
        }
      }
    },
    {
      "id": "notify_leader_disbursement",
      "type": "call",
      "call": {
        "action": "notification.send",
        "input": {
          "template": "loan_disbursed_leader",
          "data": {
            "group_id": "{{ payload.group_id }}",
            "member_id": "{{ payload.member_id }}",
            "loan_id": "{{ vars.loan.body.loan_id }}",
            "amount": "{{ vars.offer_response.amount }}"
          }
        }
      }
    }
  ]
}
