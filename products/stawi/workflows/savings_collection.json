{
  "version": "1.0",
  "name": "sacco_savings_collection",
  "description": "Manages savings collection cycle: period opened, calculate member obligations, auto-apply suspense balances, and send timed reminders",
  "timeout": "60d",
  "input": {
    "group_id": "string",
    "period_id": "string"
  },
  "retry_policy": {
    "default": {
      "max_attempts": 3,
      "backoff": "exponential",
      "initial_interval": "5s",
      "max_interval": "60s"
    }
  },
  "steps": [
    {
      "id": "fetch_group_members",
      "type": "call",
      "call": {
        "action": "http.request",
        "input": {
          "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/members?status=active",
          "method": "GET"
        },
        "output_var": "members_result",
        "retry": "default"
      }
    },
    {
      "id": "calculate_obligations",
      "type": "call",
      "call": {
        "action": "http.request",
        "input": {
          "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/periods/{{ payload.period_id }}/calculate-obligations",
          "method": "POST"
        },
        "output_var": "obligations",
        "retry": "default"
      }
    },
    {
      "id": "auto_apply_suspense",
      "type": "foreach",
      "foreach": {
        "collection": "vars.members_result.body.members",
        "item_var": "member",
        "steps": [
          {
            "id": "check_suspense_balance",
            "type": "call",
            "call": {
              "action": "http.request",
              "input": {
                "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/members/{{ vars.member.id }}/suspense-balance",
                "method": "GET"
              },
              "output_var": "suspense",
              "retry": "default"
            }
          },
          {
            "id": "check_has_suspense",
            "type": "if",
            "if": {
              "expr": "vars.suspense.body.balance > 0",
              "then": [
                {
                  "id": "apply_suspense_to_savings",
                  "type": "call",
                  "call": {
                    "action": "http.request",
                    "input": {
                      "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/members/{{ vars.member.id }}/apply-suspense",
                      "method": "POST",
                      "body": {
                        "period_id": "{{ payload.period_id }}",
                        "max_amount": "{{ vars.suspense.body.balance }}"
                      }
                    },
                    "output_var": "apply_result",
                    "retry": "default"
                  }
                },
                {
                  "id": "notify_suspense_applied",
                  "type": "if",
                  "if": {
                    "expr": "vars.apply_result.body.amount_applied > 0",
                    "then": [
                      {
                        "id": "send_suspense_applied_notification",
                        "type": "call",
                        "call": {
                          "action": "notification.send",
                          "input": {
                            "template": "suspense_auto_applied",
                            "data": {
                              "member_id": "{{ vars.member.id }}",
                              "group_id": "{{ payload.group_id }}",
                              "amount_applied": "{{ vars.apply_result.body.amount_applied }}",
                              "remaining_obligation": "{{ vars.apply_result.body.remaining_obligation }}"
                            }
                          }
                        }
                      }
                    ]
                  }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "id": "notify_obligations_due",
      "type": "foreach",
      "foreach": {
        "collection": "vars.obligations.body.member_obligations",
        "item_var": "obligation",
        "steps": [
          {
            "id": "send_obligation_notification",
            "type": "call",
            "call": {
              "action": "notification.send",
              "input": {
                "template": "savings_obligation_due",
                "data": {
                  "member_id": "{{ vars.obligation.member_id }}",
                  "group_id": "{{ payload.group_id }}",
                  "period_id": "{{ payload.period_id }}",
                  "total_due": "{{ vars.obligation.total_due }}",
                  "savings_due": "{{ vars.obligation.savings_due }}",
                  "loan_repayment_due": "{{ vars.obligation.loan_repayment_due }}",
                  "due_date": "{{ vars.obligation.due_date }}"
                }
              }
            }
          }
        ]
      }
    },
    {
      "id": "first_reminder_delay",
      "type": "delay",
      "delay": {
        "duration": "48h"
      }
    },
    {
      "id": "check_outstanding_after_first_delay",
      "type": "call",
      "call": {
        "action": "http.request",
        "input": {
          "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/periods/{{ payload.period_id }}/outstanding-obligations",
          "method": "GET"
        },
        "output_var": "outstanding_first",
        "retry": "default"
      }
    },
    {
      "id": "send_first_reminders",
      "type": "foreach",
      "foreach": {
        "collection": "vars.outstanding_first.body.members",
        "item_var": "delinquent",
        "steps": [
          {
            "id": "send_first_reminder",
            "type": "call",
            "call": {
              "action": "notification.send",
              "input": {
                "template": "savings_reminder_first",
                "data": {
                  "member_id": "{{ vars.delinquent.member_id }}",
                  "group_id": "{{ payload.group_id }}",
                  "amount_outstanding": "{{ vars.delinquent.amount_outstanding }}",
                  "due_date": "{{ vars.delinquent.due_date }}"
                }
              }
            }
          }
        ]
      }
    },
    {
      "id": "second_reminder_delay",
      "type": "delay",
      "delay": {
        "duration": "48h"
      }
    },
    {
      "id": "check_outstanding_after_second_delay",
      "type": "call",
      "call": {
        "action": "http.request",
        "input": {
          "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/periods/{{ payload.period_id }}/outstanding-obligations",
          "method": "GET"
        },
        "output_var": "outstanding_second",
        "retry": "default"
      }
    },
    {
      "id": "send_second_reminders",
      "type": "foreach",
      "foreach": {
        "collection": "vars.outstanding_second.body.members",
        "item_var": "delinquent",
        "steps": [
          {
            "id": "send_second_reminder",
            "type": "call",
            "call": {
              "action": "notification.send",
              "input": {
                "template": "savings_reminder_second",
                "data": {
                  "member_id": "{{ vars.delinquent.member_id }}",
                  "group_id": "{{ payload.group_id }}",
                  "amount_outstanding": "{{ vars.delinquent.amount_outstanding }}",
                  "due_date": "{{ vars.delinquent.due_date }}"
                }
              }
            }
          }
        ]
      }
    },
    {
      "id": "notify_leader_outstanding",
      "type": "if",
      "if": {
        "expr": "vars.outstanding_second.body.count > 0",
        "then": [
          {
            "id": "send_leader_delinquency_report",
            "type": "call",
            "call": {
              "action": "notification.send",
              "input": {
                "template": "leader_delinquency_report",
                "data": {
                  "group_id": "{{ payload.group_id }}",
                  "period_id": "{{ payload.period_id }}",
                  "delinquent_count": "{{ vars.outstanding_second.body.count }}",
                  "total_outstanding": "{{ vars.outstanding_second.body.total_outstanding }}"
                }
              }
            }
          }
        ]
      }
    },
    {
      "id": "final_reminder_delay",
      "type": "delay",
      "delay": {
        "duration": "48h"
      }
    },
    {
      "id": "check_outstanding_final",
      "type": "call",
      "call": {
        "action": "http.request",
        "input": {
          "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/periods/{{ payload.period_id }}/outstanding-obligations",
          "method": "GET"
        },
        "output_var": "outstanding_final",
        "retry": "default"
      }
    },
    {
      "id": "send_final_reminders",
      "type": "foreach",
      "foreach": {
        "collection": "vars.outstanding_final.body.members",
        "item_var": "delinquent",
        "steps": [
          {
            "id": "send_final_reminder",
            "type": "call",
            "call": {
              "action": "notification.send",
              "input": {
                "template": "savings_reminder_final",
                "data": {
                  "member_id": "{{ vars.delinquent.member_id }}",
                  "group_id": "{{ payload.group_id }}",
                  "amount_outstanding": "{{ vars.delinquent.amount_outstanding }}",
                  "due_date": "{{ vars.delinquent.due_date }}",
                  "penalty_warning": true
                }
              }
            }
          }
        ]
      }
    },
    {
      "id": "notify_leader_final_report",
      "type": "if",
      "if": {
        "expr": "vars.outstanding_final.body.count > 0",
        "then": [
          {
            "id": "send_leader_final_report",
            "type": "call",
            "call": {
              "action": "notification.send",
              "input": {
                "template": "leader_final_delinquency_report",
                "data": {
                  "group_id": "{{ payload.group_id }}",
                  "period_id": "{{ payload.period_id }}",
                  "delinquent_count": "{{ vars.outstanding_final.body.count }}",
                  "total_outstanding": "{{ vars.outstanding_final.body.total_outstanding }}"
                }
              }
            }
          }
        ]
      }
    }
  ]
}
