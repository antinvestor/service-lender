{
  "version": "1.0",
  "name": "sacco_period_lifecycle",
  "description": "Manages SACCO period lifecycle: close current period, reconcile balances, evaluate loan windows, and open next period",
  "timeout": "7d",
  "input": {
    "group_id": "string",
    "period_id": "string",
    "event_type": "string"
  },
  "retry_policy": {
    "default": {
      "max_attempts": 3,
      "backoff": "exponential",
      "initial_interval": "5s",
      "max_interval": "60s"
    }
  },
  "steps": [
    {
      "id": "route_period_event",
      "type": "if",
      "if": {
        "expr": "payload.event_type == 'close_period'",
        "then": [
          {
            "id": "freeze_contributions",
            "type": "call",
            "call": {
              "action": "http.request",
              "input": {
                "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/periods/{{ payload.period_id }}/freeze",
                "method": "POST"
              },
              "output_var": "freeze_result",
              "retry": "default"
            }
          },
          {
            "id": "reconcile_period_balances",
            "type": "call",
            "call": {
              "action": "http.request",
              "input": {
                "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/periods/{{ payload.period_id }}/reconcile",
                "method": "POST"
              },
              "output_var": "reconcile_result",
              "retry": "default"
            }
          },
          {
            "id": "calculate_penalties",
            "type": "call",
            "call": {
              "action": "http.request",
              "input": {
                "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/periods/{{ payload.period_id }}/calculate-penalties",
                "method": "POST"
              },
              "output_var": "penalty_result",
              "retry": "default"
            }
          },
          {
            "id": "notify_members_period_closed",
            "type": "foreach",
            "foreach": {
              "collection": "vars.reconcile_result.body.members",
              "item_var": "member",
              "steps": [
                {
                  "id": "send_period_summary",
                  "type": "call",
                  "call": {
                    "action": "notification.send",
                    "input": {
                      "template": "period_closed_summary",
                      "data": {
                        "group_id": "{{ payload.group_id }}",
                        "period_id": "{{ payload.period_id }}",
                        "member_id": "{{ vars.member.id }}",
                        "savings_total": "{{ vars.member.savings_total }}",
                        "penalties": "{{ vars.member.penalties }}"
                      }
                    }
                  }
                }
              ]
            }
          },
          {
            "id": "close_period_record",
            "type": "call",
            "call": {
              "action": "http.request",
              "input": {
                "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/periods/{{ payload.period_id }}/close",
                "method": "POST"
              },
              "retry": "default"
            }
          },
          {
            "id": "evaluate_loan_window",
            "type": "call",
            "call": {
              "action": "http.request",
              "input": {
                "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/evaluate-loan-window",
                "method": "POST",
                "body": {
                  "closed_period_id": "{{ payload.period_id }}"
                }
              },
              "output_var": "loan_window_result",
              "retry": "default"
            }
          },
          {
            "id": "check_loan_window_eligible",
            "type": "if",
            "if": {
              "expr": "vars.loan_window_result.body.eligible == true",
              "then": [
                {
                  "id": "open_loan_window",
                  "type": "call",
                  "call": {
                    "action": "http.request",
                    "input": {
                      "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/loan-window/open",
                      "method": "POST",
                      "body": {
                        "duration": "{{ vars.loan_window_result.body.window_duration }}"
                      }
                    },
                    "retry": "default"
                  }
                },
                {
                  "id": "notify_loan_window_open",
                  "type": "call",
                  "call": {
                    "action": "notification.send",
                    "input": {
                      "template": "loan_window_opened",
                      "data": {
                        "group_id": "{{ payload.group_id }}",
                        "window_closes_at": "{{ vars.loan_window_result.body.window_closes_at }}"
                      }
                    }
                  }
                }
              ]
            }
          },
          {
            "id": "open_next_period",
            "type": "call",
            "call": {
              "action": "http.request",
              "input": {
                "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/open-period",
                "method": "POST",
                "body": {
                  "previous_period_id": "{{ payload.period_id }}"
                }
              },
              "output_var": "new_period",
              "retry": "default"
            }
          },
          {
            "id": "notify_new_period",
            "type": "call",
            "call": {
              "action": "notification.send",
              "input": {
                "template": "new_period_opened",
                "data": {
                  "group_id": "{{ payload.group_id }}",
                  "period_id": "{{ vars.new_period.body.period_id }}",
                  "start_date": "{{ vars.new_period.body.start_date }}",
                  "end_date": "{{ vars.new_period.body.end_date }}"
                }
              }
            }
          }
        ],
        "else": [
          {
            "id": "handle_period_extend",
            "type": "if",
            "if": {
              "expr": "payload.event_type == 'extend_period'",
              "then": [
                {
                  "id": "extend_period",
                  "type": "call",
                  "call": {
                    "action": "http.request",
                    "input": {
                      "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/periods/{{ payload.period_id }}/extend",
                      "method": "POST",
                      "body": {
                        "reason": "{{ payload.reason }}"
                      }
                    },
                    "retry": "default"
                  }
                },
                {
                  "id": "notify_period_extended",
                  "type": "call",
                  "call": {
                    "action": "notification.send",
                    "input": {
                      "template": "period_extended",
                      "data": {
                        "group_id": "{{ payload.group_id }}",
                        "period_id": "{{ payload.period_id }}"
                      }
                    }
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
