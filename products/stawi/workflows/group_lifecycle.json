{
  "version": "1.0",
  "name": "sacco_group_lifecycle",
  "description": "Manages SACCO group lifecycle: formation check, welcome/activation, deactivation, restoration, and shutdown",
  "timeout": "30d",
  "input": {
    "group_id": "string",
    "event_type": "string"
  },
  "steps": [
    {
      "id": "route_event",
      "type": "if",
      "if": {
        "expr": "payload.event_type == 'member_added'",
        "then": [
          {
            "id": "check_formation",
            "type": "call",
            "call": {
              "action": "http.request",
              "input": {
                "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/check-formation",
                "method": "POST",
                "body": {}
              },
              "output_var": "formation_result"
            }
          },
          {
            "id": "check_formed",
            "type": "if",
            "if": {
              "expr": "vars.formation_result.body.formed == true",
              "then": [
                {
                  "id": "notify_leader_formation",
                  "type": "call",
                  "call": {
                    "action": "notification.send",
                    "input": {
                      "template": "group_formation_complete",
                      "data": { "group_id": "{{ payload.group_id }}" }
                    }
                  }
                }
              ],
              "else": [
                {
                  "id": "send_formation_reminder",
                  "type": "call",
                  "call": {
                    "action": "notification.send",
                    "input": {
                      "template": "group_formation_reminder",
                      "data": {
                        "group_id": "{{ payload.group_id }}",
                        "member_count": "{{ vars.formation_result.body.member_count }}",
                        "min_members": "{{ vars.formation_result.body.min_members }}"
                      }
                    }
                  }
                }
              ]
            }
          }
        ],
        "else": [
          {
            "id": "route_activate",
            "type": "if",
            "if": {
              "expr": "payload.event_type == 'activate'",
              "then": [
                {
                  "id": "setup_ledger",
                  "type": "call",
                  "call": {
                    "action": "http.request",
                    "input": {
                      "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/setup-ledger",
                      "method": "POST"
                    }
                  }
                },
                {
                  "id": "register_lender",
                  "type": "call",
                  "call": {
                    "action": "http.request",
                    "input": {
                      "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/register-lender",
                      "method": "POST"
                    }
                  }
                },
                {
                  "id": "welcome_group",
                  "type": "call",
                  "call": {
                    "action": "http.request",
                    "input": {
                      "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/welcome",
                      "method": "POST"
                    }
                  }
                },
                {
                  "id": "create_tenure",
                  "type": "call",
                  "call": {
                    "action": "http.request",
                    "input": {
                      "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/create-tenure",
                      "method": "POST"
                    }
                  }
                },
                {
                  "id": "open_first_period",
                  "type": "call",
                  "call": {
                    "action": "http.request",
                    "input": {
                      "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/open-period",
                      "method": "POST"
                    }
                  }
                },
                {
                  "id": "notify_activation",
                  "type": "call",
                  "call": {
                    "action": "notification.send",
                    "input": {
                      "template": "group_activated",
                      "data": { "group_id": "{{ payload.group_id }}" }
                    }
                  }
                }
              ],
              "else": [
                {
                  "id": "handle_shutdown",
                  "type": "if",
                  "if": {
                    "expr": "payload.event_type == 'shutdown'",
                    "then": [
                      {
                        "id": "transition_shutdown",
                        "type": "call",
                        "call": {
                          "action": "http.request",
                          "input": {
                            "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/transition",
                            "method": "POST",
                            "body": { "state": 6, "reason": "shutdown requested" }
                          }
                        }
                      },
                      {
                        "id": "notify_shutdown",
                        "type": "call",
                        "call": {
                          "action": "notification.send",
                          "input": {
                            "template": "group_shutdown",
                            "data": { "group_id": "{{ payload.group_id }}" }
                          }
                        }
                      }
                    ]
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
