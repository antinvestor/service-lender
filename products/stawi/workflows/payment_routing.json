{
  "version": "1.0",
  "name": "sacco_payment_routing",
  "description": "Routes incoming payments: receive, identify payment type, allocate to appropriate accounts, and execute transfer orders",
  "timeout": "1d",
  "input": {
    "transaction_id": "string",
    "group_id": "string",
    "sender_identifier": "string",
    "amount": "number",
    "reference": "string"
  },
  "retry_policy": {
    "default": {
      "max_attempts": 3,
      "backoff": "exponential",
      "initial_interval": "5s",
      "max_interval": "60s"
    },
    "transfer": {
      "max_attempts": 5,
      "backoff": "exponential",
      "initial_interval": "10s",
      "max_interval": "180s"
    }
  },
  "steps": [
    {
      "id": "identify_sender",
      "type": "call",
      "call": {
        "action": "http.request",
        "input": {
          "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/payments/identify-sender",
          "method": "POST",
          "body": {
            "sender_identifier": "{{ payload.sender_identifier }}",
            "group_id": "{{ payload.group_id }}",
            "reference": "{{ payload.reference }}"
          }
        },
        "output_var": "sender",
        "retry": "default"
      }
    },
    {
      "id": "check_sender_identified",
      "type": "if",
      "if": {
        "expr": "vars.sender.body.identified == false",
        "then": [
          {
            "id": "route_to_suspense",
            "type": "call",
            "call": {
              "action": "http.request",
              "input": {
                "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/suspense/deposit",
                "method": "POST",
                "body": {
                  "transaction_id": "{{ payload.transaction_id }}",
                  "amount": "{{ payload.amount }}",
                  "sender_identifier": "{{ payload.sender_identifier }}",
                  "reference": "{{ payload.reference }}"
                }
              },
              "retry": "default"
            }
          },
          {
            "id": "notify_leader_unidentified",
            "type": "call",
            "call": {
              "action": "notification.send",
              "input": {
                "template": "unidentified_payment",
                "data": {
                  "group_id": "{{ payload.group_id }}",
                  "amount": "{{ payload.amount }}",
                  "sender_identifier": "{{ payload.sender_identifier }}",
                  "transaction_id": "{{ payload.transaction_id }}"
                }
              }
            }
          },
          {
            "id": "wait_for_manual_allocation",
            "type": "signal_wait",
            "signal_wait": {
              "signal": "manual_payment_allocation",
              "filter": {
                "transaction_id": "{{ payload.transaction_id }}"
              },
              "timeout": "72h",
              "output_var": "manual_allocation"
            }
          },
          {
            "id": "check_manual_allocated",
            "type": "if",
            "if": {
              "expr": "vars.manual_allocation == null",
              "then": [
                {
                  "id": "notify_allocation_timeout",
                  "type": "call",
                  "call": {
                    "action": "notification.send",
                    "input": {
                      "template": "payment_allocation_timeout",
                      "data": {
                        "group_id": "{{ payload.group_id }}",
                        "transaction_id": "{{ payload.transaction_id }}"
                      }
                    }
                  }
                },
                {
                  "id": "end_unallocated",
                  "type": "return",
                  "return": {
                    "status": "unallocated",
                    "transaction_id": "{{ payload.transaction_id }}"
                  }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "id": "allocate_payment",
      "type": "call",
      "call": {
        "action": "http.request",
        "input": {
          "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/payments/allocate",
          "method": "POST",
          "body": {
            "transaction_id": "{{ payload.transaction_id }}",
            "member_id": "{{ vars.sender.body.member_id }}",
            "amount": "{{ payload.amount }}"
          }
        },
        "output_var": "allocation",
        "retry": "default"
      }
    },
    {
      "id": "execute_transfer_orders",
      "type": "foreach",
      "foreach": {
        "collection": "vars.allocation.body.transfer_orders",
        "item_var": "order",
        "steps": [
          {
            "id": "execute_single_transfer",
            "type": "call",
            "call": {
              "action": "http.request",
              "input": {
                "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/ledger/transfer",
                "method": "POST",
                "body": {
                  "from_account": "{{ vars.order.from_account }}",
                  "to_account": "{{ vars.order.to_account }}",
                  "amount": "{{ vars.order.amount }}",
                  "type": "{{ vars.order.type }}",
                  "reference": "{{ payload.transaction_id }}"
                }
              },
              "output_var": "transfer_result",
              "retry": "transfer"
            }
          },
          {
            "id": "check_transfer_success",
            "type": "if",
            "if": {
              "expr": "vars.transfer_result.status_code != 200",
              "then": [
                {
                  "id": "log_transfer_failure",
                  "type": "call",
                  "call": {
                    "action": "http.request",
                    "input": {
                      "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/ledger/transfer-failure",
                      "method": "POST",
                      "body": {
                        "order": "{{ vars.order }}",
                        "transaction_id": "{{ payload.transaction_id }}",
                        "error": "{{ vars.transfer_result.body }}"
                      }
                    }
                  }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "id": "confirm_payment",
      "type": "call",
      "call": {
        "action": "http.request",
        "input": {
          "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/payments/{{ payload.transaction_id }}/confirm",
          "method": "POST"
        },
        "retry": "default"
      }
    },
    {
      "id": "notify_member_payment_received",
      "type": "call",
      "call": {
        "action": "notification.send",
        "input": {
          "template": "payment_received",
          "data": {
            "member_id": "{{ vars.sender.body.member_id }}",
            "group_id": "{{ payload.group_id }}",
            "amount": "{{ payload.amount }}",
            "transaction_id": "{{ payload.transaction_id }}",
            "allocations": "{{ vars.allocation.body.transfer_orders }}"
          }
        }
      }
    },
    {
      "id": "check_savings_fulfilled",
      "type": "call",
      "call": {
        "action": "http.request",
        "input": {
          "url": "{{ env.STAWI_SERVICE_URL }}/api/v1/groups/{{ payload.group_id }}/members/{{ vars.sender.body.member_id }}/check-obligations",
          "method": "GET"
        },
        "output_var": "obligations",
        "retry": "default"
      }
    },
    {
      "id": "check_all_obligations_met",
      "type": "if",
      "if": {
        "expr": "vars.obligations.body.all_met == true",
        "then": [
          {
            "id": "notify_obligations_complete",
            "type": "call",
            "call": {
              "action": "notification.send",
              "input": {
                "template": "obligations_fulfilled",
                "data": {
                  "member_id": "{{ vars.sender.body.member_id }}",
                  "group_id": "{{ payload.group_id }}"
                }
              }
            }
          }
        ]
      }
    }
  ]
}
